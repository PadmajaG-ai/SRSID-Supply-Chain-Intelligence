# .streamlit/secrets.toml.example
# Copy to secrets.toml locally, or paste into Streamlit Cloud → App Settings → Secrets
# NEVER commit secrets.toml to git

[database]
DB_HOST     = "your-host.supabase.co"
DB_PORT     = "5432"
DB_NAME     = "postgres"
DB_USER     = "postgres.xxxx"
DB_PASSWORD = "your-password"
